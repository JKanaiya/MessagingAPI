generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Chatroom {
  id       Int       @id @default(autoincrement())
  messages Message[]
  userId   Int?
}

model User {
  id       Int       @id @default(autoincrement())
  email    String    @unique
  name     String
  password String
  messages Message[]
}

model Message {
  id          Int       @id @default(autoincrement())
  chatroom    Chatroom? @relation(fields: [chatroomId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  chatroomId  Int?
  text        String
  timeSent    DateTime
  timeUpdated DateTime?
  userId      Int
}
